{
  "apiVersion": "gateway.networking.k8s.io/v1",
  "kind": "Gateway",
  "metadata": {
    "labels": {
      "k8s.joshcorp.co/app": "envoy-gateway"
    },
    "name": "http"
  },
  "spec": {
    "gatewayClassName": "eg",
    "infrastructure": {
      "parametersRef": {
        "group": "gateway.envoyproxy.io",
        "kind": "EnvoyProxy",
        "name": "tailscale"
      }
    },
    "listeners": [
      {
        "allowedRoutes": {
          "namespaces": {
            "from": "All"
          }
        },
        "name": "http",
        "port": 80,
        "protocol": "HTTP"
      },
      {
        "allowedRoutes": {
          "namespaces": {
            "from": "All"
          }
        },
        "hostname": "*.joshcorp.co",
        "name": "https",
        "port": 443,
        "protocol": "HTTPS",
        "tls": {
          "certificateRefs": [
            {
              "group": "",
              "kind": "Secret",
              "name": "joshcorp-tls"
            }
          ],
          "mode": "Terminate"
        }
      }
    ]
  }
}
