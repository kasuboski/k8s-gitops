{
  "apiVersion": "secrets.doppler.com/v1alpha1",
  "kind": "DopplerSecret",
  "metadata": {
    "labels": {
      "k8s.joshcorp.co/app": "secrets"
    },
    "name": "tailscale",
    "namespace": "doppler-operator-system"
  },
  "spec": {
    "managedSecret": {
      "name": "operator-oauth",
      "namespace": "tailscale"
    },
    "nameTransformer": "lower-snake",
    "tokenSecret": {
      "name": "tailscale-token"
    }
  }
}
