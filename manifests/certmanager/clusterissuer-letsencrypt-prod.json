{
  "apiVersion": "cert-manager.io/v1",
  "kind": "ClusterIssuer",
  "metadata": {
    "labels": {
      "k8s.joshcorp.co/app": "certmanager"
    },
    "name": "letsencrypt-prod"
  },
  "server": "https://acme-v02.api.letsencrypt.org/directory",
  "solvers": [
    {
      "dns01": {
        "cloudflare": {
          "apiTokenSecretRef": {
            "key": "API_TOKEN",
            "name": "cert-manager"
          }
        }
      }
    }
  ],
  "spec": {
    "acme": {
      "privateKeySecretRef": {
        "name": "letsencrypt-prod"
      }
    }
  }
}
